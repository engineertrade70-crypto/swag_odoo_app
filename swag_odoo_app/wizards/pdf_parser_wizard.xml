<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Wizard View: PDF Parser -->
        <record id="view_pdf_parser_wizard_form" model="ir.ui.view">
            <field name="name">pdf.parser.wizard.form</field>
            <field name="model">swag.pdf.parser</field>
            <field name="arch" type="xml">
                <form string="PDF Invoice Parser">
                    <group string="Upload PDF">
                        <field name="pdf_file" filename="pdf_filename"/>
                        <field name="pdf_filename" invisible="1"/>
                    </group>
                    <group string="Extracted Data" attrs="{'invisible': [('extracted_codes', '=', False)]}">
                        <field name="extracted_codes" readonly="1"/>
                    </group>
                    <footer>
                        <button name="action_parse_pdf" string="Parse PDF" type="object" class="btn-primary"/>
                        <button name="action_copy_to_search" string="Copy to Search" type="object" class="btn-secondary"
                            attrs="{'invisible': [('extracted_codes', '=', False)]}"/>
                        <button string="Close" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- Action -->
        <record id="action_pdf_parser_wizard" model="ir.actions.act_window">
            <field name="name">PDF Invoice Parser</field>
            <field name="res_model">swag.pdf.parser</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <!-- Menu Item -->
        <menuitem id="menu_swag_pdf_parser"
            name="PDF Parser"
            parent="menu_swag_root"
            action="action_pdf_parser_wizard"
            sequence="30"/>

    </data>
</odoo>
