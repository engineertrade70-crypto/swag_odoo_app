<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Form View: SWAG Product Search -->
        <record id="view_swag_product_search_form" model="ir.ui.view">
            <field name="name">swag.product.search.form</field>
            <field name="model">swag.product.search</field>
            <field name="arch" type="xml">
                <form string="SWAG Product Search">
                    <header>
                        <button name="action_search" string="Search Products" type="object" class="btn-primary"/>
                        <button name="action_export_excel" string="Export Excel" type="object" class="btn-secondary"/>
                    </header>
                    <sheet>
                        <group string="Search Parameters">
                            <field name="config_id"/>
                            <field name="search_codes" placeholder="One product code per line..."/>
                            <field name="exact_match"/>
                            <field name="low_stock"/>
                        </group>
                        <group string="Results">
                            <field name="results" readonly="1"/>
                            <field name="excel_file" filename="filename"/>
                            <field name="filename" invisible="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Tree View -->
        <record id="view_swag_product_search_tree" model="ir.ui.view">
            <field name="name">swag.product.search.tree</field>
            <field name="model">swag.product.search</field>
            <field name="arch" type="xml">
                <tree string="SWAG Product Searches">
                    <field name="config_id"/>
                    <field name="exact_match"/>
                    <field name="low_stock"/>
                </tree>
            </field>
        </record>

        <!-- Action -->
        <record id="action_swag_product_search" model="ir.actions.act_window">
            <field name="name">Product Search</field>
            <field name="res_model">swag.product.search</field>
            <field name="view_mode">form,tree</field>
        </record>

        <!-- Menu Item -->
        <menuitem id="menu_swag_product_search"
            name="Product Search"
            parent="menu_swag_root"
            action="action_swag_product_search"
            sequence="10"/>

    </data>
</odoo>
